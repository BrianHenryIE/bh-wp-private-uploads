{
  "$schema": "https://schemas.wp.org/trunk/wp-env.json",
  "config": {
    "WP_DEBUG_LOG": "/var/www/html/wp-content/debug.log",
    "DISALLOW_FILE_EDIT": false
  },
  "core": "WordPress/WordPress#7.0",
  "mysqlPort": 33066,
  "lifecycleScripts": {
    "afterStart": "# bash 'tests/_wp-env/initialize-external.sh'"
  },
  "mappings": {
    "../setup": "./tests/_wp-env",
    "wp-content/plugins/debug-log-manager": "./wp-content/plugins/debug-log-manager",
    "wp-content/plugins/development-plugin": "./development-plugin",
    "wp-content/plugins/document-generator-for-openapi": "./wp-content/plugins/document-generator-for-openapi",
    "wp-content/plugins/monkeyman-rewrite-analyzer": "./wp-content/plugins/monkeyman-rewrite-analyzer",
    "wp-content/plugins/query-monitor": "./wp-content/plugins/query-monitor",
    "wp-content/plugins/woocommerce": "./wp-content/plugins/woocommerce",
    "wp-content/plugins/wp-rest-api-log": "./wp-content/plugins/wp-rest-api-log",
    "wp-content/themes": "./wp-content/themes",
    "wp-content/uploads/development-plugin/assets": "./assets",
    "wp-content/uploads/development-plugin/includes": "./includes",
    "wp-content/uploads/development-plugin/vendor": "./vendor"
  },
  "phpVersion": "8.1",
  "testsEnvironment": false
}
