{
    "name": "brianhenryie/bh-wp-private-uploads",
    "description": "WordPress library for serving private/protected file uploads.",
    "type": "library",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "BrianHenryIE",
            "email": "BrianHenryIE@gmail.com"
        },
        {
            "name": "Chris Dennis",
            "email": "cgdennis@btinternet.com"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "process-timeout": 0,
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "johnpbloch/wordpress-core-installer": true,
            "phpstan/extension-installer": true
        },
        "platform": {
            "php": "8.1"
        }
    },
    "autoload": {
        "classmap": [
            "includes/",
            "assets/"
        ],
        "files": [
            "includes/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "BrianHenryIE\\WP_Private_Uploads\\": [
                "tests/unit",
                "tests/wpunit",
                "tests/integration"
            ]
        },
        "classmap": [
            "tests/",
            "tests/_support/"
        ]
    },
    "repositories": {
        "outlandishideas/wpackagist": {
            "type": "composer",
            "url": "https://wpackagist.org"
        },
        "wordpress/wordpress": {
            "url": "https://github.com/wordpress/wordpress-develop.git",
            "type": "git"
        }
    },
    "require": {
        "php": ">=8.1",
        "ext-fileinfo": "*",
        "psr/log": "^1 || ^2 || ^3",
        "wptrt/admin-notices": "^1.0"
    },
    "require-dev": {
        "ext-json": "*",
        "10up/wp_mock": "^1.0",
        "alleyinteractive/wordpress-autoloader": "^1.1",
        "antecedent/patchwork": "^2.1",
        "behat/behat": "^3.29",
        "brianhenryie/color-logger": "*",
        "codeception/codeception": "^5.2.2",
        "dealerdirect/phpcodesniffer-composer-installer": "*",
        "dvdoug/behat-code-coverage": "^5.3",
        "johnpbloch/wordpress": "*",
        "kamazee/pr-filter": "^1.1",
        "lucatume/wp-browser": "^4",
        "phpstan/extension-installer": "*",
        "phpunit/phpcov": "*",
        "rector/rector": "^2.4",
        "squizlabs/php_codesniffer": "*",
        "szepeviktor/phpstan-wordpress": "*",
        "wordpress/wordpress": "*",
        "wp-coding-standards/wpcs": "*",
        "wpackagist-plugin/debug-log-manager": "*",
        "wpackagist-plugin/document-generator-for-openapi": "*",
        "wpackagist-plugin/monkeyman-rewrite-analyzer": "*",
        "wpackagist-plugin/query-monitor": "*",
        "wpackagist-plugin/woocommerce": "*",
        "wpackagist-plugin/wp-rest-api-log": "*",
        "wpackagist-theme/twentytwenty": "*"
    },
    "scripts": {
        "post-install-cmd": [
            "@sync-composer-wpenv",
            "@sync-wpenv-phpstorm",
            "@install-wp-cli"
        ],
        "post-update-cmd": [
            "@sync-composer-wpenv",
            "@sync-wpenv-phpstorm",
            "@install-wp-cli"
        ],
        "test": [
            "codecept run unit",
            "codecept run wpunit"
        ],
        "test-coverage": [
            "codecept run unit --coverage unit.cov",
            "codecept run wpunit --coverage wpunit.cov",
            "phpcov merge --clover tests/_output/clover.xml --html tests/_output/html tests/_output;",
            "open tests/_output/html/index.html"
        ],
        "behat": [
            "WP_CLI_TEST_DBTYPE=sqlite vendor/bin/behat -c behat.php"
        ],
        "behat-coverage": [
            "rm -f tests/_output/behat-*.xml tests/_output/behat-*.php || true",
            "rm -rf tests/_output/behat-html || true",
            "XDEBUG_MODE=coverage WP_CLI_TEST_DBTYPE=sqlite vendor/bin/behat -c behat.php --profile=coverage",
            "echo '\\n✓ Coverage reports generated:'",
            "echo '  - HTML: tests/_output/behat-html/index.html'",
            "echo '  - Clover XML: tests/_output/behat-clover.xml'"
        ],
        "cs-fix": [
            "phpcbf || true",
            "@cs"
        ],
        "cs": [
            "phpcs || true",
            "phpstan analyse --memory-limit 1G"
        ],
        "cs-strict": [
            "phpcs || true",
            "phpstan analyse --level max --memory-limit 1G"
        ],
        "cs-changes": [
            "updated_files=$(echo $(git diff --name-only `git merge-base origin/master HEAD` | grep \\.php | tr '\\n' '\\0' | xargs -0 ls -1df 2>/dev/null)); if [ -n \"$updated_files\" ]; then phpcbf $(echo $updated_files); phpcs $(echo $updated_files); phpstan analyse $(echo $updated_files) --memory-limit 1G; else echo \"No modified php files for phpstan.\"; fi;"
        ],
        "cs-changes-strict": [
            "updated_files=$(echo $(git diff --name-only `git merge-base origin/master HEAD` | grep \\.php | tr '\\n' '\\0' | xargs -0 ls -1df 2>/dev/null)); if [ -n \"$updated_files\" ]; then phpcbf $(echo $updated_files); phpcs $(echo $updated_files); phpstan analyse $(echo $updated_files) --level max --memory-limit 1G; else echo \"No modified php files for phpstan.\"; fi;"
        ],
        "create-plugin-archive": [
            "wp i18n make-pot includes languages/$(basename \"$PWD\").pot --domain=$(basename \"$PWD\")",
            "wp dist-archive development-plugin ./dist-archive --plugin-dirname=development-plugin --create-target-dir"
        ],
        "github-actions": [
            "act -P ubuntu-latest=shivammathur/node:latest"
        ],
        "install-wp-cli": [
            "php ./bin/set-composer-provides.php",
            "COMPOSER=composer-wp-cli.json composer update"
        ],
        "sync-composer-wpenv": [
            "php ./bin/sync-composer-wpenv.php"
        ],
        "sync-wpenv-phpstorm": [
            "php bin/wpenv-mappings-to-phpstorm.php"
        ],
        "generate-openapi": [
            "npx wp-env run cli /var/www/html/wp-content/plugins/development-plugin/vendor/bin/wp openapi-generator export-file development-plugin/v1 --destination=./openapi/development-plugin-openapi.json --extract-common-types;",
            "cat ./openapi/development-plugin-openapi.json | jq 'del(.servers) | del(.paths.\"/\") | .jsonSchemaDialect = \"https://spec.openapis.org/oas/3.1/dialect/base\"' | sponge ./openapi/development-plugin-openapi.json"
        ],
        "generate-wp-cli-docs": [
            "npx wp-env run cli /var/www/html/wp-content/plugins/development-plugin/vendor/bin/wp handbook gen-custom development-plugin --output_dir=docs/wp-cli;",
            "rm -rf docs/wp-cli/development-plugin/logger; rm docs/wp-cli/development-plugin/logger.md;"
        ]
    }
}
